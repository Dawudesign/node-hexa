{
  "name": "@dawudesign/node-hexa-cli",
  "version": "0.4.1",
  "description": "CLI to scaffold and analyze NestJS Hexagonal DDD projects",
  "keywords": [
    "nestjs",
    "hexagonal",
    "ddd",
    "architecture",
    "cli",
    "scaffold"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "node-hexa": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dawudesign/node-hexa.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/Dawudesign/node-hexa#readme",
  "bugs": {
    "url": "https://github.com/Dawudesign/node-hexa/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@node-hexa/core": "workspace:^",
    "@node-hexa/parser": "workspace:^",
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
