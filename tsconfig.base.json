{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@node-hexa/core": ["./packages/core/src/index.ts"],
      "@node-hexa/model": ["./packages/model/src/index.ts"],
      "@node-hexa/parser": ["./packages/parser/src/index.ts"]
