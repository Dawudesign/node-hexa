{
  "name": "@node-hexa/parser",
  "version": "0.1.0",
  "description": "TypeScript source parser for node-hexa",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@node-hexa/model": "workspace:^",
    "ts-morph": "^27.0.2"
  }
}